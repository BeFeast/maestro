# Maestro configuration example
# Copy this file to maestro.yaml and fill in your values.
#
# For multi-project setups, create separate files:
#   maestro-panoptikon.yaml, maestro-self.yaml, etc.

repo: YOUR_ORG/YOUR_REPO
local_path: /path/to/local/repo
worktree_base: /path/to/worktrees/repo
max_parallel: 5
max_runtime_minutes: 120           # hard timeout per worker (default: 120)
worker_silent_timeout_minutes: 0   # kill worker if tmux output is unchanged for N min (0 = disabled)
worker_max_tokens: 0               # kill worker when cumulative token usage exceeds this (0 = unlimited)
auto_rebase: true                  # auto-rebase conflicting PR branches (default: true)
merge_strategy: sequential         # "sequential" (default) or "parallel"
merge_interval_seconds: 30         # minimum seconds between sequential merges (default: 30)
review_gate: greptile              # "greptile" (default) or "none"
auto_retry_review_feedback: false  # retry PRs with actionable review comments
auto_retry_rebase_conflicts: false # retry PRs whose auto-rebase fails with conflicts

# Files to auto-resolve conflicts by keeping both sides during rebase.
# Useful for generated/aggregated files that accumulate changes from multiple branches.
# auto_resolve_files:
#   - server/src/api/mod.rs
#   - web/src/lib/api.ts
#   - web/src/lib/types.ts

# Model backend — default is Claude CLI
# Supported: claude (default), codex (OpenAI), gemini, cline
claude_cmd: claude                 # deprecated: use model.backends.claude.cmd
issue_labels:                      # label filter (OR semantics); use issue_label for single label
  - enhancement
model:
  default: claude
  backends:
    claude:
      cmd: claude
    codex:
      cmd: codex
    gemini:
      cmd: gemini
    cline:
      cmd: cline          # Cline CLI — configure provider in ~/.cline/data/globalState.json
exclude_labels:
  - blocked
  - wontfix

# Worker prompt template (Markdown file with instructions for AI workers)
worker_prompt: /path/to/worker-prompt-template.md

# Test-first prompt variant — enforces write-tests-before-implementation workflow.
# Uses {{VALIDATION_CONTRACT}} placeholder which is replaced with VALIDATION.md content
# from the worktree (generated by the after_create hook below).
# worker_prompt: /path/to/worker-prompt-tdd.md

# Workspace lifecycle hooks
# hooks:
#   after_create: ./scripts/generate-validation.sh  # generates VALIDATION.md in worktree
#   before_run: ""                                   # runs before each agent attempt (fatal on failure)
#   after_run: ""                                    # runs after each agent attempt (logged, not fatal)
#   before_remove: ""                                # runs before workspace cleanup
#   timeout_ms: 60000                                # hook timeout in milliseconds

# Optional: command to run after successful merge (build + deploy)
# deploy_cmd: "cd /path/to/repo && go build ./cmd/app/ && systemctl --user restart app"
# deploy_timeout_minutes: 15         # timeout for deploy command in minutes (default: 15)

# Telegram notifications
telegram:
  target: "YOUR_TELEGRAM_CHAT_ID"
  bot_token: "YOUR_TELEGRAM_BOT_TOKEN"
  # mode: "direct" (Telegram Bot API) or "openclaw" (OpenClaw relay)
  # default: "direct"
  mode: direct
  # only needed when mode: openclaw
  # openclaw_url: "http://localhost:18789"
